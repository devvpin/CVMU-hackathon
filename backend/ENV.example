## Backend (Express) environment variables
## Copy this file to `.env` (do not commit `.env`)

# Server port (optional)
PORT=5000

# Gemini API key for AI endpoints (optional; AI endpoints will gracefully degrade without it)
GEMINI_API_KEY=your_gemini_api_key

# Firebase Admin
# This project initializes Firebase Admin from `backend/serviceAccountKey.json` if present.
# Keep that file OUT of git. (It is already ignored by `.gitignore`.)


